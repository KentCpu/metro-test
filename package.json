    "@mantine/hooks": "^9.3.1",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.78.0",
    "react-map-gl": "^8.1.1",
    "react-router": "^7.17.0",
